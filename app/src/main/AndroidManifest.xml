            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
        <activity
            android:name=".xmlui.CategoryFormActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
        <activity
            android:name=".xmlui.CategoryPickerActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
        <activity
            android:name=".xmlui.HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
        <activity
            android:name=".xmlui.HistoryFilterActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
        <activity
            android:name=".xmlui.WalletSuccessActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
        <activity
            android:name=".xmlui.AddTransactionActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication.AddTransaction" />
        <activity
            android:name=".xmlui.ReportActivity"
            android:exported="false"
            android:theme="@style/Theme.MyApplication" />
        <activity
