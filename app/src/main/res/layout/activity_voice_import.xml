<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_voice_entry_gradient">

    <ImageButton
        android:id="@+id/btnVoiceBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="@dimen/screen_top_safe_margin"
        android:background="@android:color/transparent"
        android:contentDescription="@string/action_back"
        android:padding="8dp"
        android:src="@drawable/ic_wallet_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <TextView
        android:id="@+id/tvVoiceTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/voice_entry_title"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnVoiceBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnVoiceBack" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardVoiceResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:visibility="gone"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnVoiceBack"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="10dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/ivVoiceResultIcon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_add_quick_icon"
                android:contentDescription="@null"
                android:padding="10dp"
                android:src="@drawable/ic_overview_bag"
                app:layout_constraintBottom_toBottomOf="@id/tvVoiceResultDate"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvVoiceResultCategory"
                app:tint="@color/expense_red" />

            <TextView
                android:id="@+id/tvVoiceResultCategory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="8dp"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvVoiceResultAmount"
                app:layout_constraintStart_toEndOf="@id/ivVoiceResultIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvVoiceResultNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="italic"
                app:layout_constraintEnd_toEndOf="@id/tvVoiceResultCategory"
                app:layout_constraintStart_toStartOf="@id/tvVoiceResultCategory"
                app:layout_constraintTop_toBottomOf="@id/tvVoiceResultCategory" />

            <TextView
                android:id="@+id/tvVoiceResultDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/tvVoiceResultCategory"
                app:layout_constraintStart_toStartOf="@id/tvVoiceResultCategory"
                app:layout_constraintTop_toBottomOf="@id/tvVoiceResultNote" />

            <TextView
                android:id="@+id/tvVoiceResultAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/expense_red"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/btnVoiceResultClose"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="@id/tvVoiceResultAmount"
                app:layout_constraintTop_toBottomOf="@id/tvVoiceResultAmount">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_wallet_wallet"
                    app:tint="@color/add_mode_blue" />

                <TextView
                    android:id="@+id/tvVoiceResultPayment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnVoiceResultEdit"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/voice_entry_edit_title"
                android:padding="6dp"
                android:src="@drawable/ic_action_edit"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnVoiceResultClose"
                app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnVoiceResultClose"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/action_cancel"
                android:padding="4dp"
                android:src="@drawable/ic_voice_close"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_secondary" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/layoutVoiceCenterIcon"
        android:layout_width="92dp"
        android:layout_height="92dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_voice_center_icon"
        app:layout_constraintBottom_toTopOf="@id/btnVoiceDelete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardVoiceResult"
        app:layout_constraintVertical_bias="0.32">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_add_quick_icon"
            android:contentDescription="@null"
            android:padding="10dp"
            android:src="@drawable/ic_wallet_wallet"
            app:tint="@color/add_mode_blue" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvVoiceHintChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_voice_hint_chip"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        android:text="@string/voice_entry_hint_chip"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutVoiceCenterIcon" />

    <TextView
        android:id="@+id/tvVoiceExample"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:text="@string/voice_entry_example"
        android:textColor="@android:color/white"
        android:textSize="17sp"
        app:layout_constraintBottom_toTopOf="@id/btnVoiceDelete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvVoiceHintChip" />

    <ImageButton
        android:id="@+id/btnVoiceDelete"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="38dp"
        android:layout_marginBottom="88dp"
        android:background="@drawable/bg_voice_action_circle"
        android:contentDescription="@string/action_delete"
        android:padding="14dp"
        android:src="@drawable/ic_wallet_delete"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@android:color/white" />

    <ImageButton
        android:id="@+id/btnVoiceApply"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="38dp"
        android:layout_marginBottom="88dp"
        android:background="@drawable/bg_voice_action_circle"
        android:contentDescription="@string/action_done"
        android:padding="14dp"
        android:src="@drawable/ic_action_check"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@android:color/white" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabVoiceRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="76dp"
        android:contentDescription="@string/content_voice_entry"
        app:backgroundTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/ic_voice_mic"
        app:tint="@color/add_mode_blue" />

    <TextView
        android:id="@+id/tvVoiceActionHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/voice_entry_action_idle"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fabVoiceRecord" />

    <TextView
        android:id="@+id/tvVoiceStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnVoiceDelete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layoutVoiceLoading"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#88000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:id="@+id/progressVoiceLoading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:indeterminateTint="@android:color/white" />

        <TextView
            android:id="@+id/tvVoiceLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/voice_entry_status_processing"
            android:textColor="@android:color/white"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
