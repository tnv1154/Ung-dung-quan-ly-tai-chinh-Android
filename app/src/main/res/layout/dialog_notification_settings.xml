<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="4dp"
    android:paddingEnd="8dp"
    android:paddingBottom="4dp">

    <CheckBox
        android:id="@+id/cbNotificationBudgetExceeded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_notification_budget_exceeded" />

    <CheckBox
        android:id="@+id/cbNotificationMonthlyReport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/label_notification_monthly_report_enabled" />

    <CheckBox
        android:id="@+id/cbNotificationReminderEnabled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/label_notification_reminder_enabled" />

    <RadioGroup
        android:id="@+id/rgNotificationReminderMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbNotificationReminderDaily"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_notification_mode_daily" />

        <RadioButton
            android:id="@+id/rbNotificationReminderWeekly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="@string/label_notification_mode_weekly" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNotificationReminderTime"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/action_pick_reminder_time" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNotificationReminderDays"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/action_pick_reminder_days" />

    <TextView
        android:id="@+id/tvNotificationReminderHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/notification_reminder_hint"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />
</LinearLayout>

