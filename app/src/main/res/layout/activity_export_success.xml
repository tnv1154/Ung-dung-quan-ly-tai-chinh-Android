<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft">

    <TextView
        android:id="@+id/btnExportSuccessClose"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="@dimen/screen_top_safe_margin"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:contentDescription="@string/content_close"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:text="@string/symbol_close"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutExportSuccessActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnExportSuccessClose">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="126dp"
                android:layout_height="126dp">

                <View
                    android:layout_width="126dp"
                    android:layout_height="126dp"
                    android:background="@drawable/bg_export_success_circle" />

                <View
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_export_icon_circle_excel"
                    android:backgroundTint="@color/export_format_excel_icon" />

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_action_check"
                    app:tint="@android:color/white" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_export_icon_circle_excel"
                    android:backgroundTint="@color/export_success_dot" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="start|bottom"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_export_icon_circle_excel"
                    android:backgroundTint="@color/export_success_dot" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/export_success_title"
                android:textColor="@color/text_primary"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/export_success_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="17sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_export_file_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="12dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_export_icon_circle_pdf"
                    android:gravity="center"
                    android:text="@string/export_format_pdf_short"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvExportSuccessFileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvExportSuccessFileMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnExportSuccessShare"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/export_success_share_chooser_title"
                    android:focusable="true"
                    android:padding="5dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="@color/blue_primary" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutExportSuccessActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportSuccessGoHome"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/export_success_action_home" />

        <TextView
            android:id="@+id/tvExportSuccessOpenFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/export_success_action_open_file"
            android:textColor="@color/blue_primary"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_bottom_nav"
        app:itemActiveIndicatorStyle="@null"
        app:itemIconSize="21dp"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:itemTextAppearanceActive="@style/TextAppearance.MyApp.BottomNav"
        app:itemTextAppearanceInactive="@style/TextAppearance.MyApp.BottomNav"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/menu_bottom_nav" />

</androidx.constraintlayout.widget.ConstraintLayout>

